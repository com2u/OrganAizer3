# === Terminlandschaft System Configuration ===
# Copy this file to `.env` and adjust the values as needed.

# Web server
WEB_PORT=4815
WEB_HOST=0.0.0.0
# Enable Flask debug mode (true/false). Keep false in production.
FLASK_DEBUG=false

# CORS: allowed frontend origins (comma separated, or "*" for all)
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:4815,http://127.0.0.1:5173,http://167.235.156.114,http://167.235.156.114:4815,http://com2u-ThinkPad-T580,http://com2u-ThinkPad-T580:5173,https://organaizer.app,http://organaizer.app

# Authentication: OpenWebUI is used as the shared login/identity backend
AUTH_ENABLED=true
OPENWEBUI_URL=https://openwebui.ai-server.org

# Database (path relative to project root, or absolute)
DB_PATH=data/terminlandschaft.db

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=log.txt

# Obsidian vault root (container path; host path is mounted via docker-compose.yml)
# Each user's vault lives at $OBSIDIAN_ROOT/<user-email>/
# Access is enforced per-user by the application; do NOT change to a single-user path.
OBSIDIAN_ROOT=/app/obsidian
