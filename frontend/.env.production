# Production build configuration (read automatically by `vite build`).
# The ionos-hosted frontend (organaizer.app) talks to the backend on the
# AI server via its HTTPS reverse-proxy subdomain.
VITE_API_BASE=https://terminlandschaft-api.ai-server.org/api

# Assistant (Hermes via OpenWebUI) embedded in the "Assistent" tab
VITE_ASSISTANT_URL=https://openwebui.ai-server.org/
